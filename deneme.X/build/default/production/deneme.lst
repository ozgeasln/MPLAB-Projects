                      00047     ; Kesme Ayarlari
                      00048 
000C   3088           00049     MOVLW   B'10001000'   ; GIE=1 (Genel Kesme Acik), RBIE=1 (RB4-RB7 Degisiklik Kesmesi Acik)
                      00050 
000D   008B           00051     MOVWF   INTCON
                      00052 
000E   1283           00053     BCF     STATUS, RP0   ; Bank 0'a don
                      00054 
                      00055 
